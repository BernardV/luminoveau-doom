diff --git a/cmake/ShaderTranspile.cmake b/cmake/ShaderTranspile.cmake
index 19f9628..517be7d 100644
--- a/cmake/ShaderTranspile.cmake
+++ b/cmake/ShaderTranspile.cmake
@@ -100,11 +100,13 @@ if(NOT EXISTS "${LUMI_TINT_EXECUTABLE}")
         # When cross-compiling, CMAKE_C/CXX_COMPILER point to emcc.
         # We need the native compiler instead.
         if(EMSCRIPTEN)
-            # Try to find the native compiler
-            find_program(_NATIVE_CC NAMES cc gcc clang cl
+            # Try to find the native compiler. Prefer clang: recent Dawn has a C++20
+            # module target that only clang (+ clang-scan-deps) can scan — GCC can't,
+            # so the host configure fails. clang is also what macOS uses.
+            find_program(_NATIVE_CC NAMES clang cc gcc cl
                 PATHS /usr/bin /usr/local/bin
                 NO_CMAKE_FIND_ROOT_PATH)
-            find_program(_NATIVE_CXX NAMES c++ g++ clang++ cl
+            find_program(_NATIVE_CXX NAMES clang++ c++ g++ cl
                 PATHS /usr/bin /usr/local/bin
                 NO_CMAKE_FIND_ROOT_PATH)
 
@@ -133,7 +135,13 @@ if(NOT EXISTS "${LUMI_TINT_EXECUTABLE}")
                 -G Ninja
                 ${_HOST_COMPILER_ARGS}
                 -DCMAKE_BUILD_TYPE=Release
+                # GCC+Ninja can't scan Dawn's C++20 module target; we only need tint.
+                -DCMAKE_CXX_SCAN_FOR_MODULES=OFF
                 -DDAWN_BUILD_SAMPLES=OFF
+                # No GLFW: the tint CLI doesn't need it, and configuring it on Linux/CI
+                # needs X11/Wayland dev libs (and fails under emcmake's pkg-config).
+                -DDAWN_USE_GLFW=OFF
+                -DDAWN_ENABLE_DESKTOP_GL=OFF
                 -DDAWN_BUILD_TESTS=OFF
                 -DDAWN_BUILD_BENCHMARKS=OFF
                 -DTINT_BUILD_TESTS=OFF
